# Local SQLite profile (development/test)
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENV=development
TESTING=false

# Local DB
DATABASE_URL=sqlite:///./smart_attendance.db

# Supabase placeholders for local compatibility
# SUPABASE_URL -> Supabase Dashboard > Settings > API > Project URL
SUPABASE_URL=https://abcdemo12345.supabase.co
# SUPABASE_ANON_KEY -> Supabase Dashboard > Settings > API > anon public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.local-anon-key
# ⚠️ SUPABASE_SERVICE_KEY -> Supabase Dashboard > Settings > API > service_role
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.local-service-key
# ⚠️ ENCRYPTION_KEY -> python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

SECRET_KEY=local-secret-key-please-change-this-in-real-deployment
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081
ADMIN_EMAIL=admin@attendance.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_NAME=System Administrator

FACE_SIMILARITY_THRESHOLD=0.4
FACE_LIVENESS_THRESHOLD=0.5
DEFAULT_GEOFENCE_RADIUS_M=50
MAX_GPS_ACCURACY_M=30.0
GPS_ACCURACY_THRESHOLD=80.0
QR_TOKEN_TTL_SECONDS=60
LOGIN_RATE_LIMIT=10/minute

COOKIE_SECURE=false
COOKIE_SAMESITE=lax
